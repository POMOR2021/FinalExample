<Window x:Class="FinalClentApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinalClentApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="900"
        Background="#FFFFFF"
        FontFamily="Calibri">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#DAA520">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="/Recources/icon.ico" Height="60" Width="120" Margin="10,5" HorizontalAlignment="Left"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10" VerticalAlignment="Center">
                <Button x:Name="ViewOrderButton" Click="ViewOrderButton_Click" Content="Просмотр заказа" 
                        Width="130" Height="30" Margin="0,0,15,0" Background="#B8860B" Foreground="White" 
                        Visibility="Collapsed"/>

                <TextBlock x:Name="FullNameTextBlock" Text="Гость" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="White"/>
                <Button x:Name="SignInButton" Click="SignInButton_Click" Width="100" Height="30" Content="Войти" Background="#B8860B" Foreground="White"/>
                <Button x:Name="LogoutButton" Content="Выйти" Width="80" Height="30" Click="LogoutButton_Click" Visibility="Collapsed" Background="#B8860B" Foreground="White" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Background="#F5F5F5" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.Row="0" Margin="10,5">
                <TextBlock Text="Поиск по наименованию:" FontSize="12" Foreground="Gray" Margin="0,0,0,2"/>
                <TextBox x:Name="SearchTextBox" TextChanged="SearchTextBox_TextChanged" Height="25" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,5">
                <TextBlock Text="Производитель:" FontSize="12" Foreground="Gray" Margin="0,0,0,2"/>
                <ComboBox x:Name="ManufacturerComboBox" SelectionChanged="ManufacturerComboBox_SelectionChanged" Height="25"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Grid.Row="0" Margin="10,5">
                <TextBlock Text="Сортировка:" FontSize="12" Foreground="Gray" Margin="0,0,0,2"/>
                <ComboBox x:Name="SortComboBox" ItemsSource="{Binding SortOptions}" SelectionChanged="SortComboBox_SelectionChanged" SelectedIndex="0" Height="25"/>
            </StackPanel>

            <StackPanel Grid.Column="3" Grid.Row="0" Margin="10,5">
                <TextBlock Text="Цена (Мин. / Макс.):" FontSize="12" Foreground="Gray" Margin="0,0,0,2"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="MinPriceTextBox" TextChanged="MinPriceTextBox_TextChanged" Height="25" VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text=" - " VerticalAlignment="Center" Margin="2,0"/>
                    <TextBox Grid.Column="2" x:Name="MaxPriceTextBox" TextChanged="MaxPriceTextBox_TextChanged" Height="25" VerticalContentAlignment="Center"/>
                </Grid>
            </StackPanel>

            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" x:Name="TxtRecordsInfo" Text="Количество элементов: 0 из 0" FontWeight="SemiBold" Margin="10,2,10,5" Foreground="#B8860B" HorizontalAlignment="Left"/>
        </Grid>

        <ListBox x:Name="BooksListBox" Grid.Row="2" HorizontalContentAlignment="Stretch" Margin="10" BorderThickness="0" Padding="0" Background="#FFFFFF">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="16" Margin="0,0,0,4" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,4"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Производитель: " />
                                <TextBlock Text="{Binding Manufacturer}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Цена: " FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Sale, StringFormat='{}{0} руб.'}"/>
                            </StackPanel>
                        </StackPanel>

                        <Button x:Name="AddToOrderButton" Grid.Column="1" Content="Заказать" Width="90" Height="30" Padding="5" 
                                VerticalAlignment="Center" Margin="15,0,5,0" Click="AddToOrderButton_Click" 
                                Background="#B8860B" Foreground="White"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>