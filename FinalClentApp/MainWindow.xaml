<Window x:Class="FinalClentApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinalClentApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Background="#FFFFFF"
        FontFamily="Calibri">
    <!-- Исправлена опечатка в пути и добавлена иконка окна -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Дополнительный фон по стилю #DAA520 -->
        <Grid Grid.Row="0" Background="#DAA520">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Логотип приложения (исправлена опечатка Recources -> Resources) -->
            <Image Grid.Column="0" Source="/Recources/icon.ico" Height="100" Width="200" Margin="10,5" HorizontalAlignment="Left"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10" VerticalAlignment="Center">
                <TextBlock x:Name="TxtUserFIO" Text="Гость" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="Bold" Foreground="White"/>
                <!-- Целевые действия покрашены в акцентный цвет #B8860B -->
                <Button x:Name="SignInButton" Click="SignInButton_Click" Width="100" Height="30" Content="Войти" Background="#B8860B" Foreground="White" BorderThickness="0"/>
                <Button x:Name="LogoutButton" Content="Выйти" Width="80" Height="30" Click="LogoutButton_Click" Visibility="Collapsed" Background="#B8860B" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>

        <!-- Основной фон #FFFFFF и скрытая рамка ListBox -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Books}" HorizontalContentAlignment="Stretch" Margin="10" 
                 BorderThickness="0" Padding="0" Background="#FFFFFF">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="16" Margin="0,0,0,4" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,4"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Производитель: " />
                                <TextBlock Text="{Binding Manufacturer}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Цена: " FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Price, StringFormat='{}{0} руб.'}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Кнопка целевого действия покрашена в акцентный цвет #B8860B -->
                        <Button x:Name="OrderButton" Grid.Column="1" Content="Заказать" Width="90" Height="30" Padding="5" VerticalAlignment="Center" Margin="15,0,5,0" Click="OrderButton_Click" Background="#B8860B" Foreground="White" BorderThickness="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.UserRole, RelativeSource={RelativeSource AncestorType=Window}}" Value="Администратор">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DataContext.UserRole, RelativeSource={RelativeSource AncestorType=Window}}" Value="Менеджер">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
